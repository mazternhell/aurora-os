{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "aurora-sam-pmo",
  "main": "src/index.js",
  "compatibility_date": "2026-07-17",
  "workers_dev": true,
  "preview_urls": true,
  "observability": {
    "enabled": true
  },
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "WORKERS_AI_MODEL": "@cf/meta/llama-3.1-8b-instruct",
    "ALLOWED_ORIGIN": "https://mazternhell.github.io"
  }
}
